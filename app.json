{
  "expo": {
    "name": "CamotesRunner",
    "slug": "CamotesRunner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "camotesrunner",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EAF6EE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.camotesrunner.customer"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Camotes Runner to use your location for pickup and delivery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B5D1E",
          "image": "./assets/images/logo.png",
          "imageWidth": 96,
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 96
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4c94e57a-1554-4477-8f2c-ee5a5f07230b"
      }
    }
  }
}
