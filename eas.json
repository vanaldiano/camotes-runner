{
  "cli": {
    "version": ">= 20.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "customerPreview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "customer",
        "EXPO_PUBLIC_APP_VARIANT": "customer"
      }
    },
    "riderPreview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "rider",
        "EXPO_PUBLIC_APP_VARIANT": "rider"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
